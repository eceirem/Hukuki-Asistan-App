# ==========================================
# CORS SETTINGS
# ==========================================
# Comma-separated list of allowed frontend origins.
# Development default shown below. For production, replace with your real domain.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ==========================================
# DATABASE & SECURITY SETTINGS
# ==========================================
# Update with your actual database credentials
DATABASE_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/hukuki_asistan

# To generate a secure secret key, run this command in your terminal:
# openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# EXPLAINABLE AI (XAI) SETTINGS
# ==========================================
# Explainable-AI for "Neden bu karar getirildi?"
#   False (default) -> frontend shows the best-matching chunk from hybrid search.
#   True            -> backend calls xai_service via the HF Inference Router.
ENABLE_LLM_XAI=False

# Hugging Face Inference Router — required when ENABLE_LLM_XAI=True
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ------------------------------------------
# Legacy Aliases (Kept for reference)
# No longer read by xai_service.py but kept for backward compatibility reference.
# ------------------------------------------
LLM_API_URL=https://router.huggingface.co/v1
LLM_API_TOKEN=hf_your_token_here
LLM_MODEL_NAME=ytu-ce-cosmos/Turkish-Gemma-9b-T1